# ══════════════════════════════════════════════════════════════════════════════
# WPO Translations — STAGING environment variables (web app / Vercel Preview)
# Copy these into Vercel → Project → Settings → Environment Variables
# Set scope to "Preview" only — DO NOT set on Production.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Environment identity ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_SITE_URL=https://<vercel-preview-url>.vercel.app

# ─── Supabase STAGING project ──────────────────────────────────────────────────
# Create a separate Supabase project "WorldPrimeOnline Staging"
# NEVER use production Supabase credentials here
NEXT_PUBLIC_SUPABASE_URL=https://<staging-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# ─── AI / LLM keys ─────────────────────────────────────────────────────────────
# Can share the same API keys as production (no data isolation risk)
ANTHROPIC_API_KEY=<your-anthropic-key>
MISTRAL_API_KEY=<your-mistral-key>

# ─── Cloudflare R2 STAGING bucket ──────────────────────────────────────────────
# Use a SEPARATE bucket: wpo-staging-documents
# NEVER point to production bucket here
R2_ACCOUNT_ID=<your-r2-account-id>
R2_ACCESS_KEY_ID=<staging-r2-access-key>
R2_SECRET_ACCESS_KEY=<staging-r2-secret-key>
R2_BUCKET_NAME=wpo-staging-documents

# ─── Email (Resend) — STAGING safety ──────────────────────────────────────────
RESEND_API_KEY=<your-resend-key>
# Disable real emails entirely in staging:
EMAILS_ENABLED=false
# OR redirect all to an internal address (used when EMAILS_ENABLED=true):
# EMAIL_REDIRECT_ALL_TO=staging-test@yourdomain.com

# ─── Payments — TEST mode only ─────────────────────────────────────────────────
# NEVER use production Halyk terminal in staging
PAYMENTS_MODE=test
HALYK_TERMINAL_ID=<halyk-test-terminal-id>
HALYK_CLIENT_ID=<halyk-test-client-id>
HALYK_CLIENT_SECRET=<halyk-test-client-secret>

# ─── Official/notary workflow ──────────────────────────────────────────────────
OFFICIAL_WORKFLOW_ENABLED=true

# ─── Jira webhook (Vercel only — receives callbacks from Jira Automation) ──────
# Jira issue CREATION and Google Drive are Railway worker responsibilities.
# These vars belong in worker/.env.staging (NOT here):
#   JIRA_BASE_URL, JIRA_EMAIL, JIRA_API_TOKEN, JIRA_PROJECT_KEY, GOOGLE_*
JIRA_WEBHOOK_SECRET=<random-secret-match-jira-automation>

# ─── Telegram notifications (Vercel — fired by Jira webhook handler on sync) ───
# Can use the same bot with staging-specific channels.
TELEGRAM_BOT_TOKEN=<bot-token>
TELEGRAM_OPERATOR_CHAT_ID=<staging-operator-chat-id>
TELEGRAM_TRANSLATOR_CHAT_ID=<staging-translator-chat-id>
TELEGRAM_NOTARY_CHAT_ID=<staging-notary-chat-id>

# ─── Vercel Cron ───────────────────────────────────────────────────────────────
CRON_SECRET=<random-staging-secret>

# ─── Monitoring (optional for staging) ────────────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
