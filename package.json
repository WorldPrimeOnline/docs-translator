{
  "name": "docs-translator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "staging:check": "node scripts/staging-check.mjs",
    "i18n:check": "tsx scripts/i18n/check-messages.ts",
    "i18n:check:strict": "tsx scripts/i18n/check-messages.ts --strict",
    "i18n:hardcoded": "tsx scripts/i18n/find-hardcoded-ui-text.ts",
    "i18n:forbidden": "tsx scripts/i18n/find-forbidden-phrases.ts",
    "i18n:routes": "tsx scripts/i18n/check-routes.ts",
    "i18n:language": "tsx scripts/i18n/find-wrong-language.ts",
    "i18n:validate": "npm run i18n:check && npm run i18n:forbidden && npm run i18n:language",
    "i18n:rendered": "tsx scripts/i18n/check-rendered-pages.ts",
    "i18n:validate:rendered": "npm run i18n:validate && npm run i18n:rendered",
    "partners:payouts": "tsx scripts/partners/generate-monthly-payout.ts",
    "partners:mark-paid": "tsx scripts/partners/mark-payout-paid.ts",
    "wpo:ai-test": "tsx tools/internal-ai-test-lab/run-ai-translation-test.ts",
    "wpo:ai-test:typecheck": "tsc --noEmit -p tools/internal-ai-test-lab/tsconfig.json",
    "pricing:calculate": "tsx tools/pricing-cli/index.ts",
    "pricing:fixtures": "tsx tools/pricing-cli/fixtures.ts",
    "pricing:typecheck": "tsc --noEmit -p tools/pricing-cli/tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.54.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@ton/ton": "^16.2.4",
    "@tonconnect/ui-react": "^2.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js-light": "^2.5.1",
    "docx": "^9.7.1",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "next": "15.5.18",
    "next-intl": "^4.12.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.76.1",
    "resend": "^6.12.3",
    "shadcn": "^4.8.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@jest/globals": "^30.4.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
