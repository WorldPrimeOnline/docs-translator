# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
worker/node_modules
worker/dist
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.pdf

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — commit .env.example, never commit secrets
.env.local
.env*.local

# Internal AI Translation Test Lab — local runs and secrets only, never commit
tools/internal-ai-test-lab/.env*.local
tools/internal-ai-test-lab/runs/*
!tools/internal-ai-test-lab/runs/.gitkeep
tools/internal-ai-test-lab/input/*
!tools/internal-ai-test-lab/input/.gitkeep

# editor
.vscode/

# tooling
.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated test artifacts
/tmp

# Postman exports / API collections / local API credentials
*.postman_collection.json
*.postman_environment.json
*postman_collection*.json
*postman_environment*.json
Postman/
postman/
collections/
environments/

# Webkassa / integrator exported API docs with possible secrets
*ИНТЕГРАТОРЫ*.json
*integrator*.json
*webkassa*collection*.json
*webkassa*environment*.json

# Local secret dumps
*.secrets.json
*.tokens.json
*.credentials.json
