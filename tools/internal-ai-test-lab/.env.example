# ============================================================
# WPO Internal AI Translation Test Lab
#
# Copy this file to one of:
#   tools/internal-ai-test-lab/.env.production.local
#   tools/internal-ai-test-lab/.env.staging.local
#   tools/internal-ai-test-lab/.env.local.local   (pure local/dev testing)
#
# NEVER COMMIT REAL VALUES. All *.local files are gitignored.
#
# Variable names below match exactly what the REAL pipeline modules already
# read (worker/src/lib/env.ts, src/lib/supabase/server.ts) — this tool does
# not invent new env vars, per CLAUDE.md §15.
# ============================================================

# ────────────────────────────────────────────────────────────
# REQUIRED — always
# ────────────────────────────────────────────────────────────

# Determines the safety tier this run operates under. See README.md
# "Production safety rules". Use "staging" for normal testing.
APP_ENV=staging
NEXT_PUBLIC_APP_ENV=staging
NODE_ENV=production

# The CLI refuses to run at all unless this is "true", in every environment.
AI_TRANSLATION_TEST_LAB_ENABLED=true

# Only enforced when APP_ENV/NEXT_PUBLIC_APP_ENV=production: must be "true"
# AND --confirm-production must be passed on the command line to run against
# prod. Leave "false" for staging/local — it is not checked in those tiers.
AI_TRANSLATION_TEST_LAB_ALLOW_PRODUCTION=false

AI_TRANSLATION_TEST_LAB_OPERATOR_EMAIL=admin@example.com
AI_TRANSLATION_TEST_LAB_MAX_FILE_MB=20
AI_TRANSLATION_TEST_LAB_MAX_PAGES=30

MISTRAL_API_KEY=REPLACE_ME
ANTHROPIC_API_KEY=REPLACE_ME

# ────────────────────────────────────────────────────────────
# REQUIRED — but only because this tool reuses the REAL worker modules
# ────────────────────────────────────────────────────────────
# Not required by this tool's own logic — required because
# worker/src/lib/env.ts validates the FULL worker env schema unconditionally
# at module *import* time, and importing any worker/src/lib/* module (OCR,
# translator, renderer, docx-renderer, pdf, qa, r2, ...) pulls env.ts in.
# This is true even if you never pass --save-to-r2. Do not treat these as
# optional just because a given run doesn't "need" R2/Supabase conceptually.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# Real names — NOT "CLOUDFLARE_R2_*".
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET_NAME=REPLACE_ME

# ────────────────────────────────────────────────────────────
# Must NEVER be true in production
# ────────────────────────────────────────────────────────────
# The CLI fails hard if APP_ENV/NEXT_PUBLIC_APP_ENV=production AND this is
# "true", regardless of any other flag. Leave unset/false everywhere.
# ALLOW_STAGING_PAYMENT_OVERRIDE=false

# ────────────────────────────────────────────────────────────
# Optional
# ────────────────────────────────────────────────────────────
LOG_LEVEL=info

# Model is hardcoded in worker/src/lib/ocr.ts ("mistral-ocr-latest") — not
# currently read from env. Kept here for documentation only.
# MISTRAL_OCR_MODEL=mistral-ocr-latest

# Model is hardcoded in worker/src/lib/translator.ts / detect-language.ts /
# page-vision.ts ("claude-sonnet-4-5-20250929") — not currently read from env.
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ────────────────────────────────────────────────────────────
# Explicitly NOT required and must NOT be relied upon by this tool
# ────────────────────────────────────────────────────────────
# This tool never imports any module under these prefixes. See
# __tests__/no-forbidden-integrations.test.ts, which statically asserts this.
# HALYK_*
# JIRA_*
# WEBKASSA_*
# OFD_*
# RESEND_*
