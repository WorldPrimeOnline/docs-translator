# ─── Environment ────────────────────────────────────────────────────────────────
# Values: production | staging | development
NEXT_PUBLIC_APP_ENV=production

# ─── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://wpotranslations.org

# ─── Supabase (database & auth) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI / LLM keys ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# ─── Cloudflare R2 (file storage) ──────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wpo-documents

# ─── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
# EMAILS_ENABLED=true
# EMAIL_REDIRECT_ALL_TO=   # if set, all outgoing emails go here instead of real recipients

# ─── Payments ──────────────────────────────────────────────────────────────────
# PAYMENTS_MODE=live        # live | test — defaults to live in production
# HALYK_TERMINAL_ID=
# HALYK_CLIENT_ID=
# HALYK_CLIENT_SECRET=

# ─── Official/notary workflow ──────────────────────────────────────────────────
# OFFICIAL_WORKFLOW_ENABLED=true

# ─── Jira integration (certified / notarized orders) ───────────────────────────
# JIRA_BASE_URL=https://yourorg.atlassian.net
# JIRA_EMAIL=service-account@example.com
# JIRA_API_TOKEN=
# JIRA_WEBHOOK_SECRET=   # random secret; configure matching value in Jira Automation
# JIRA_PROJECT_KEY=WO    # Jira project key (default: WO)

# ─── Google Drive integration ──────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_DRIVE_ROOT_FOLDER_ID=  # shared root folder ID from Drive URL

# ─── Telegram notifications ────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_OPERATOR_CHAT_ID=
# TELEGRAM_TRANSLATOR_CHAT_ID=
# TELEGRAM_NOTARY_CHAT_ID=

# ─── Vercel Cron (auto-delete after 30 days) ───────────────────────────────────
CRON_SECRET=

# ─── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
