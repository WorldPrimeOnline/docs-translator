# ─── Supabase (Stage 1 — database & auth) ─────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI / LLM keys (Stage 3 — translation pipeline) ───────────────────────────
# Anthropic Claude — primary translation model
ANTHROPIC_API_KEY=

# Google Gemini — fallback for CJK languages
GEMINI_API_KEY=

# Mistral — primary OCR ($0.001/page)
MISTRAL_API_KEY=

# Google Document AI — OCR fallback (JSON credentials blob, base64 or inline)
GOOGLE_DOCUMENT_AI_CREDENTIALS_JSON=

# ─── Polar (Stage 8 — payments, replaces Stripe) ──────────────────────────────
# API key from Polar dashboard → Settings → Developers → API Keys
POLAR_API_KEY=

# Webhook signing secret from Polar dashboard → Webhooks
# Webhook URL: https://docs-translator.vercel.app/api/webhooks/polar
POLAR_WEBHOOK_SECRET=

# Product IDs from Polar dashboard → Products
POLAR_PRODUCT_ID_SMALL=       # 1–5 pages, $4.99 (required)
POLAR_PRODUCT_ID_PASSPORT=    # Passport / Driver license, $3.99 (optional, falls back to SMALL)
POLAR_PRODUCT_ID_MEDIUM=      # 6–15 pages, $7.49 (optional, falls back to SMALL)
POLAR_PRODUCT_ID_LARGE=       # 16–50 pages, $12.49 (optional, falls back to SMALL)

# ─── Site URL (required for Polar/Stripe redirects in production) ──────────────
# Full URL without trailing slash, e.g. https://docs-translator.vercel.app
NEXT_PUBLIC_SITE_URL=

# ─── Stripe (Stage 4 — payments) ───────────────────────────────────────────────
# Secret key — server-side only
STRIPE_SECRET_KEY=

# Webhook signing secret (from Stripe dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=

# Publishable key — safe to expose to browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Cloudflare R2 (Stage 3 — file storage) ────────────────────────────────────
# Account ID from Cloudflare dashboard
R2_ACCOUNT_ID=

# R2 API token access key ID
R2_ACCESS_KEY_ID=

# R2 API token secret access key
R2_SECRET_ACCESS_KEY=

# Name of the R2 bucket
R2_BUCKET_NAME=

# ─── Job queue (Stage 3 — worker) ──────────────────────────────────────────────
# Redis connection URL (Railway addon)
REDIS_URL=

# ─── Inngest (Stage 3 — background jobs, alternative to BullMQ+Redis) ──────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Email (Stage 4 — notifications) ───────────────────────────────────────────
# Resend API key
RESEND_API_KEY=

# ─── Vercel Cron (auto-delete after 30 days) ───────────────────────────────────
# Random secret — set in Vercel env vars; Vercel sends it as Authorization: Bearer <secret>
CRON_SECRET=

# ─── Monitoring (Stage 5 — observability) ──────────────────────────────────────
# Sentry DSN from Sentry project settings
SENTRY_DSN=
