# ─── Supabase (database & auth) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI / LLM keys ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# ─── Cloudflare R2 (file storage) ──────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ─── Site URL (used in redirect links) ─────────────────────────────────────────
# Full URL without trailing slash, e.g. https://docs-translator.vercel.app
NEXT_PUBLIC_SITE_URL=

# ─── Vercel Cron (auto-delete after 30 days) ───────────────────────────────────
# Random secret — set in Vercel env vars; Vercel sends it as Authorization: Bearer <secret>
CRON_SECRET=

# ─── TON payments ──────────────────────────────────────────────────────────────
# Optional: set in tonconsole webhook config and here to verify webhook requests
TONCONSOLE_WEBHOOK_SECRET=

# ─── Monitoring ────────────────────────────────────────────────────────────────
# SENTRY_DSN is used server-side (API routes, server components)
SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN is used client-side (browser errors)
# Can be the same DSN as SENTRY_DSN — it's safe to expose in browser
NEXT_PUBLIC_SENTRY_DSN=
# Sentry org/project for source map upload at build time (optional)
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source map upload (set in CI/Vercel, not in repo)
SENTRY_AUTH_TOKEN=
