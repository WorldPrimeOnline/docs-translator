# ─── Environment ────────────────────────────────────────────────────────────────
# Values: production | staging | development
NEXT_PUBLIC_APP_ENV=production

# ─── Site URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://wpotranslations.org

# ─── Supabase (database & auth) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI / LLM keys ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# ─── Cloudflare R2 (file storage) ──────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wpo-documents

# ─── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
# EMAILS_ENABLED=true
# EMAIL_REDIRECT_ALL_TO=   # if set, all outgoing emails go here instead of real recipients

# ─── Payments — Halyk ePay ────────────────────────────────────────────────────
# Server-side gate — controls upload-card route and initiate route.
HALYK_EPAY_ENABLED=false
# Client-side feature flag — shows "Upload & Pay by card" button. Set same as HALYK_EPAY_ENABLED.
NEXT_PUBLIC_HALYK_EPAY_ENABLED=false
# test | production  (never switch to production without full staging QA)
HALYK_EPAY_MODE=test
# Credentials from Halyk Bank manager (never commit real values)
HALYK_EPAY_CLIENT_ID=
HALYK_EPAY_CLIENT_SECRET=
HALYK_EPAY_TERMINAL_ID=
# Server-only base URL for postLink / backLink callback construction.
# Must be HTTPS in production. Falls back to NEXT_PUBLIC_SITE_URL if unset.
APP_BASE_URL=

# ─── Fiscalization ────────────────────────────────────────────────────────────
# Set to true only after fiscal provider credentials are confirmed with accountant.
# false (default) = all receipts are pending_manual; operator issues via OFD cabinet.
# FISCALIZATION_ENABLED=false
#
# Fiscal provider. Currently only 'manual' is supported.
# Future: 'rekassa' | 'webkassa' | 'wofd' (when provider contract is signed)
# FISCAL_PROVIDER=manual
#
# Must match HALYK_EPAY_MODE. Prevents test receipts in production OFD.
# FISCAL_PROVIDER_ENV=test
#
# Provider-specific credentials (fill when a real provider is chosen):
# FISCAL_API_BASE_URL=
# FISCAL_CLIENT_ID=
# FISCAL_API_KEY=
# FISCAL_CASHBOX_ID=       # KKM serial number
# FISCAL_OFD_ID=           # OFD operator identifier
# FISCAL_TAXPAYER_ID=      # ИИН/БИН of the entity
# FISCAL_BUSINESS_ID=      # provider-specific business identifier

# ─── Official/notary workflow ──────────────────────────────────────────────────
# OFFICIAL_WORKFLOW_ENABLED=true

# ─── Jira webhook (Vercel only — receives callbacks from Jira Automation) ──────
# Jira issue CREATION and Google Drive live in the Railway worker, not Vercel.
# JIRA_WEBHOOK_SECRET=   # random secret; configure matching value in Jira Automation

# ─── Telegram notifications (Vercel — webhook handler fires these on sync) ──────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_OPERATOR_CHAT_ID=
# TELEGRAM_TRANSLATOR_CHAT_ID=
# TELEGRAM_NOTARY_CHAT_ID=

# ─── Vercel Cron (auto-delete after 30 days) ───────────────────────────────────
CRON_SECRET=

# ─── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
